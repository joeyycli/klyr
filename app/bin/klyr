#!/bin/bash
# klyr — AI No-Code Builder
# Run this to start a new session or connect to an existing one.

set -e

KLYR_HOME="${KLYR_HOME:-$HOME/.klyr}"
PORT="${KLYR_PORT:-8000}"
VERSION="1.0.0"

# Colors
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
WHITE='\033[97m'

print_logo() {
  echo ""
  echo -e "${WHITE}${BOLD}  klyr${RESET} ${DIM}v${VERSION}${RESET}"
  echo ""
}

# Check Node.js
if ! command -v node &>/dev/null; then
  print_logo
  echo "  Error: Node.js is required."
  echo "  Install: https://nodejs.org or 'brew install node'"
  echo ""
  exit 1
fi

# Check if server is already running
server_running() {
  curl -sf "http://localhost:$PORT" > /dev/null 2>&1
}

# Start server if not running
start_server() {
  if server_running; then
    return 0
  fi

  if [ ! -f "$KLYR_HOME/server.js" ]; then
    echo "  Error: klyr not installed properly."
    echo "  Missing: $KLYR_HOME/server.js"
    echo "  Reinstall with: curl -fsSL http://localhost:$PORT/install | bash"
    echo ""
    exit 1
  fi

  echo -e "  ${DIM}Starting server on port $PORT...${RESET}"
  cd "$KLYR_HOME"
  node server.js > "$KLYR_HOME/klyr.log" 2>&1 &
  KLYR_PID=$!
  echo $KLYR_PID > "$KLYR_HOME/klyr.pid"

  # Wait for server to be ready
  for i in {1..20}; do
    if server_running; then
      echo -e "  ${DIM}Server ready (PID: $KLYR_PID)${RESET}"
      return 0
    fi
    sleep 0.3
  done

  echo "  Error: Server failed to start. Check $KLYR_HOME/klyr.log"
  exit 1
}

# Create a new session
create_session() {
  local response
  response=$(curl -sf -X POST "http://localhost:$PORT/api/sessions" 2>/dev/null)

  if [ -z "$response" ]; then
    echo "  Error: Could not create session"
    exit 1
  fi

  # Parse JSON with node (available since we checked earlier)
  echo "$response" | node -e "
    let d='';
    process.stdin.on('data',c=>d+=c);
    process.stdin.on('end',()=>console.log(JSON.parse(d).sessionId));
  "
}

# Main
print_logo
start_server

# Handle arguments
case "${1:-}" in
  stop)
    if [ -f "$KLYR_HOME/klyr.pid" ]; then
      kill $(cat "$KLYR_HOME/klyr.pid") 2>/dev/null && echo "  Server stopped." || echo "  Server not running."
      rm -f "$KLYR_HOME/klyr.pid"
    else
      echo "  No server to stop."
    fi
    exit 0
    ;;
  status)
    if server_running; then
      echo "  Server is running on port $PORT"
    else
      echo "  Server is not running"
    fi
    exit 0
    ;;
  open)
    # Open existing session
    if [ -n "${2:-}" ]; then
      echo -e "  ${DIM}Opening session ${2}...${RESET}"
      open "http://localhost:$PORT/$2" 2>/dev/null || xdg-open "http://localhost:$PORT/$2" 2>/dev/null || echo "  Open: http://localhost:$PORT/$2"
      exit 0
    fi
    ;;
  *)
    ;;
esac

# Create new session
SESSION=$(create_session)

echo ""
echo -e "  ${BOLD}Session:${RESET}  $SESSION"
echo -e "  ${BOLD}URL:${RESET}      http://localhost:$PORT/$SESSION"
echo ""
echo -e "  ${DIM}Paste the session ID on the website, or open the URL above.${RESET}"
echo -e "  ${DIM}Run 'klyr stop' to shut down the server.${RESET}"
echo ""

# Open in browser
open "http://localhost:$PORT/$SESSION" 2>/dev/null || xdg-open "http://localhost:$PORT/$SESSION" 2>/dev/null || true
